# LicenseGuard — variables à ajouter au .env du projet client
# (seules les 3 premières sont obligatoires)
LICENSE_API_URL=http://localhost:8000/api/license/check
LICENSE_KEY=LIC-XXXX-XXXX-XXXX-XXXX
LICENSE_SECRET=

# Options facultatives (défauts sûrs)
LICENSE_ENABLED=true
LICENSE_FAIL_OPEN=true
LICENSE_CACHE_HOURS=6
LICENSE_TIMEOUT=5
